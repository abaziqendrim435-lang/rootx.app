# ============================================================
# RootX — Environment Variables Template
#
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Get from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Admin Dashboard ──────────────────────────────────────────
# Simple password to protect the /admin page
# Change this to a strong password before deploying!
ADMIN_PASSWORD=rootx_admin_2024

# ── Stripe (Placeholder — for future payments) ───────────────
# Get from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_here

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
