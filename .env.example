# ============================================================
# RootX — Environment Variables Reference
#
# Copy this file: cp .env.example .env.local
# Fill in all values before running locally or deploying.
#
# For Vercel: add these in Project → Settings → Environment Variables
# ============================================================

# ── OpenAI ───────────────────────────────────────────────────
# Required for: AI content generation (Content Creator + Shopify agents)
# Without this: agents run in demo/mock mode
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ── Supabase ─────────────────────────────────────────────────
# Required for: user auth, dashboard history, subscriptions
# Without this: app falls back to localStorage (no auth)
# Get from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Stripe ───────────────────────────────────────────────────
# Required for: pricing plans, checkout, subscription management
# Without this: pricing page runs in demo mode (fake upgrade)
#
# Get from: https://dashboard.stripe.com/apikeys
# Use sk_live_... / pk_live_... for production
# Use sk_test_... / pk_test_... for local testing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# Stripe Price IDs — create products in Stripe Dashboard → Products
# Each product needs a monthly recurring price; copy its Price ID (price_xxx)
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...

# Stripe Webhook Signing Secret
# Get from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# For Vercel: https://your-app.vercel.app/api/stripe/webhook
# For local testing: use Stripe CLI → stripe listen --forward-to localhost:3001/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App URL ───────────────────────────────────────────────────
# Production: your Vercel deployment URL (no trailing slash)
# Local:      http://localhost:3001
# Vercel sets VERCEL_URL automatically — override with your custom domain
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Admin ─────────────────────────────────────────────────────
# Simple password for the /admin page — change before deploying!
ADMIN_PASSWORD=change-me-before-deploying
